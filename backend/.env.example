PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/rythmOS
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Default daily routine inputs used by cron-generated schedules
DEFAULT_WAKEUP_TIME=07:00
DEFAULT_SLEEP_TIME=23:00
DEFAULT_LUNCH_TIME=13:00
DEFAULT_LUNCH_DURATION_MINUTES=60

CRON_TIMEZONE=Asia/Kolkata
CLIENT_ORIGIN=http://localhost:5173

